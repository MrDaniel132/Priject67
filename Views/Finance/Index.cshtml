@{
    ViewData["Title"] = "Аналитика продаж";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="main-container page-shell">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold h3 mb-1">Реальная аналитика продаж</h1>
            <p class="text-muted mb-0">Показатели считаются из таблиц sales, sale_items, purchases и текущего каталога склада</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-dark" data-bs-toggle="modal" data-bs-target="#financeConnectModal"><i class="bi bi-database-add me-2"></i>Подключить БД</button>
            <button class="btn btn-outline-dark" id="exportAnalyticsBtn"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Экспорт CSV</button>
            <button class="btn btn-dark" id="printAnalyticsBtn"><i class="bi bi-printer me-2"></i>Печать / PDF</button>
        </div>
    </div>

    <ul class="nav nav-pills app-tabs mb-4">
        @if (User.IsInRole("Кассир") || User.IsInRole("Администратор") || User.IsInRole("Менеджер") || User.IsInRole("Кладовщик"))
        {
            @* каталог *@
            <li class="nav-item"><a class="nav-link active" asp-controller="Parts" asp-action="Index"><i class="bi bi-list-ul me-2"></i>Каталог товаров</a></li>
        }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кассир"))
        {
            @* продажи *@
            <li class="nav-item"><a class="nav-link" asp-controller="Sales" asp-action="Index"><i class="bi bi-bag-check me-2"></i>Продажи</a></li>
        }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кладовщик") || User.IsInRole("Менеджер"))
        {
            @* закупки *@
            <li class="nav-item"><a class="nav-link" asp-controller="Purchases" asp-action="Index"><i class="bi bi-truck me-2"></i>Закупки</a></li>
        }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кладовщик") || User.IsInRole("Менеджер"))
        {
            @* поставщики *@
            <li class="nav-item"><a class="nav-link" asp-controller="Suppliers" asp-action="Index"><i class="bi bi-truck-flatbed me-2"></i>Поставщики</a></li>
        }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кассир") || User.IsInRole("Менеджер"))
        {
            @* категории *@
            <li class="nav-item"><a class="nav-link" asp-controller="Categories" asp-action="Index"><i class="bi bi-tags me-2"></i>Категории</a></li>
        }
        @if (User.IsInRole("Администратор"))
        {
            @* журнал *@
            <li class="nav-item"><a class="nav-link" asp-controller="Audit" asp-action="Index"><i class="bi bi-journal-text me-2"></i>Журнал действий</a></li>
        }
        @if (User.IsInRole("Администратор") || User.IsInRole("Менеджер"))
        {
            @* аналитика *@
            <li class="nav-item"><a class="nav-link" asp-controller="Finance" asp-action="Index"><i class="bi bi-bar-chart me-2"></i>Аналитика</a></li>
        }
        @if (User.IsInRole("Администратор"))
        {
            @* сотрудники *@
            <li class="nav-item"><a class="nav-link" asp-controller="Employees" asp-action="Index"><i class="bi bi-person-circle"></i> Сотрудники</a></li>
        }
    </ul>

    <div class="card app-card border-0 mb-4">
        <div class="card-body p-3 d-flex gap-3 flex-wrap align-items-end">
            <div style="min-width: 240px;">
                <label class="form-label text-muted small fw-bold mb-1">Таблица товаров</label>
                <select id="financeTableComboBox" class="form-select">
                    <option value="parts">parts</option>
                </select>
            </div>
            <div style="min-width: 180px;">
                <label class="form-label text-muted small fw-bold mb-1">Период</label>
                <select id="financePeriod" class="form-select">
                    <option value="month">Текущий месяц</option>
                    <option value="today">Сегодня</option>
                </select>
            </div>
            <button class="btn btn-dark" id="refreshFinanceBtn"><i class="bi bi-arrow-clockwise me-2"></i>Обновить показатели</button>
            <div class="small text-muted ms-auto" id="financeStatusText">Подключись к базе данных, чтобы загрузить реальные показатели.</div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Выручка за сегодня</span><i class="bi bi-lightning-charge"></i></div><div class="stat-value" id="kpiRevenueToday">0 BYN</div><div class="stat-sub">Сумма продаж за текущий день</div></div></div>
        <div class="col-md-3"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Выручка за месяц</span><i class="bi bi-graph-up-arrow"></i></div><div class="stat-value" id="kpiRevenueMonth">0 BYN</div><div class="stat-sub">Основной показатель месяца</div></div></div>
        <div class="col-md-3"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Средний чек</span><i class="bi bi-cash-stack"></i></div><div class="stat-value" id="kpiAverageCheck">0 BYN</div><div class="stat-sub">Выручка / количество продаж</div></div></div>
        <div class="col-md-3"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Прибыль за месяц</span><i class="bi bi-piggy-bank"></i></div><div class="stat-value" id="kpiProfitMonth">0 BYN</div><div class="stat-sub">Оценка по sale_items</div></div></div>
        <div class="col-md-3"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Продаж за месяц</span><i class="bi bi-receipt"></i></div><div class="stat-value" id="kpiOrdersMonth">0</div><div class="stat-sub">Количество оформленных заказов</div></div></div>
        <div class="col-md-3"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Позиций в каталоге</span><i class="bi bi-box-seam"></i></div><div class="stat-value" id="kpiPositions">0</div><div class="stat-sub">Общее число товаров</div></div></div>
        <div class="col-md-3"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Стоимость склада</span><i class="bi bi-boxes"></i></div><div class="stat-value" id="kpiInventoryValue">0 BYN</div><div class="stat-sub">Оценка текущего запаса</div></div></div>
        <div class="col-md-3"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Низкий остаток</span><i class="bi bi-exclamation-circle"></i></div><div class="stat-value" id="kpiLowStock">0</div><div class="stat-sub">Товары, требующие пополнения</div></div></div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card app-card border-0 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                        <div>
                            <h5 class="mb-1">Динамика продаж за 10 дней</h5>
                            <div class="small text-muted">Сумма выручки и количество заказов по дням</div>
                        </div>
                    </div>
                    <div id="dailySalesBars" class="mock-chart-bars"><div style="height: 8%"></div></div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card app-card border-0 h-100">
                <div class="card-body p-4">
                    <h5 class="mb-3">Выручка по категориям</h5>
                    <div id="categoryDistributionList">
                        <div class="text-muted small">Категории будут показаны после загрузки аналитики.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card app-card border-0">
                <div class="card-body p-4">
                    <h5 class="mb-3">Топ продаваемых товаров</h5>
                    <div id="topProductsList"><div class="text-muted small">Нет данных.</div></div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card app-card border-0">
                <div class="card-body p-4">
                    <h5 class="mb-3">Проблемные остатки</h5>
                    <div id="lowStockList"><div class="text-muted small">Нет данных.</div></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-lg-6">
            <div class="card app-card border-0">
                <div class="card-body p-4">
                    <h5 class="mb-3">Закупки по поставщикам</h5>
                    <div id="supplierPurchasesList"><div class="text-muted small">Нет данных.</div></div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card app-card border-0">
                <div class="card-body p-4">
                    <h5 class="mb-3">Последние заказы и прибыль</h5>
                    <div id="recentOrdersList"><div class="text-muted small">Нет данных.</div></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="financeConnectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Настройки подключения</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2"><label>Сервер</label><input type="text" id="financeDbServer" class="form-control" value="localhost"></div>
                <div class="mb-2"><label>Порт</label><input type="text" id="financeDbPort" class="form-control" value="3306"></div>
                <div class="mb-2"><label>База данных</label><input type="text" id="financeDbName" class="form-control" value="myfinanceapp_db"></div>
                <div class="row">
                    <div class="col"><label>Логин</label><input type="text" id="financeDbUser" class="form-control" value="root"></div>
                    <div class="col"><label>Пароль</label><input type="password" id="financeDbPass" class="form-control" value="root"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" id="btnFinanceConnect" class="btn btn-dark w-100">Подключиться и загрузить таблицы</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const state = { settings: null, dashboard: null };
    const localSettingsKey = 'autoPartsDbSettings';
    const el = (id) => document.getElementById(id);
    const fmtMoney = (value) => `${Number(value || 0).toLocaleString('ru-RU', { minimumFractionDigits: 0, maximumFractionDigits: 2 })} BYN`;

    function getSettingsFromForm() {
        return {
            server: el('financeDbServer').value,
            port: el('financeDbPort').value,
            database: el('financeDbName').value,
            username: el('financeDbUser').value,
            password: el('financeDbPass').value
        };
    }

    function fillSettingsForm(settings) {
        if (!settings) return;
        el('financeDbServer').value = settings.server || 'localhost';
        el('financeDbPort').value = settings.port || '3306';
        el('financeDbName').value = settings.database || 'myfinanceapp_db';
        el('financeDbUser').value = settings.username || 'root';
        el('financeDbPass').value = settings.password || 'root';
    }

    async function apiRequest(url, data) {
        const response = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        return response;
    }

    async function apiJson(url, data) {
        return (await apiRequest(url, data)).json();
    }

    function currentTableName() {
        return el('financeTableComboBox').value || 'parts';
    }

    async function connectAndLoadTables() {
        const settings = getSettingsFromForm();
        const result = await apiJson('/Database/GetTables', settings);
        if (!result.success) {
            alert(result.message || 'Не удалось подключиться к базе данных.');
            return;
        }
        state.settings = settings;
        localStorage.setItem(localSettingsKey, JSON.stringify(settings));
        const combo = el('financeTableComboBox');
        combo.innerHTML = '<option value="">Выберите таблицу</option>';
        result.tables.forEach(name => combo.insertAdjacentHTML('beforeend', `<option value="${name}">${name}</option>`));
        combo.value = result.tables.includes('parts') ? 'parts' : (result.tables[0] || '');
        bootstrap.Modal.getInstance(el('financeConnectModal'))?.hide();
        await loadDashboard();
    }

    async function loadDashboard() {
        if (!state.settings) return;
        el('financeStatusText').innerText = 'Загрузка аналитики...';
        const result = await apiJson('/Finance/GetDashboard', {
            settings: state.settings,
            inventoryTableName: currentTableName(),
            period: el('financePeriod').value,
            salesTableName: 'sales',
            saleItemsTableName: 'sale_items',
            purchasesTableName: 'purchases',
            purchaseItemsTableName: 'purchase_items',
            suppliersTableName: 'suppliers',
            categoriesTableName: 'categories'
        });

        if (!result.success) {
            el('financeStatusText').className = 'small text-danger ms-auto';
            el('financeStatusText').innerText = result.message || 'Не удалось загрузить аналитику.';
            return;
        }
        el('financeStatusText').className = 'small text-muted ms-auto';
        el('financeStatusText').innerText = 'Показатели обновлены по текущим таблицам.';
        state.dashboard = result;
        renderDashboard(result);
    }

    function renderDashboard(result) {
        const k = result.kpis || {};
        el('kpiRevenueToday').innerText = fmtMoney(k.revenueToday);
        el('kpiRevenueMonth').innerText = fmtMoney(k.revenueMonth);
        el('kpiAverageCheck').innerText = fmtMoney(k.averageCheck);
        el('kpiProfitMonth').innerText = fmtMoney(k.monthProfit);
        el('kpiOrdersMonth').innerText = k.ordersMonth || 0;
        el('kpiPositions').innerText = k.totalPositions || 0;
        el('kpiInventoryValue').innerText = fmtMoney(k.inventoryValue);
        el('kpiLowStock').innerText = k.lowStockCount || 0;

        const daily = result.dailySales || [];
        const maxRevenue = Math.max(...daily.map(x => Number(x.revenue || 0)), 1);
        el('dailySalesBars').innerHTML = daily.length ? daily.map(item => `
            <div title="${item.day}: ${fmtMoney(item.revenue)} / ${item.ordersCount} заказов" style="height:${Math.max(8, Math.round((Number(item.revenue || 0) / maxRevenue) * 100))}%"></div>
        `).join('') : '<div style="height:8%"></div>';

        fillList('categoryDistributionList', result.categoryDistribution, item => `
            <div class="analytics-list-item"><span>${item.name || 'Без категории'}</span><strong>${fmtMoney(item.revenue)}</strong></div>`);
        fillList('topProductsList', result.topProducts, item => `
            <div class="analytics-list-item"><span>${item.partName || 'Без названия'}<div class="small text-muted">${item.partNumber || 'Без артикула'}</div></span><strong>${item.quantity} шт. · ${fmtMoney(item.revenue)}</strong></div>`);
        fillList('lowStockList', result.lowStockItems, item => `
            <div class="analytics-list-item"><span>${item.partName || 'Без названия'}<div class="small text-muted">${item.partNumber || 'Без артикула'}</div></span><strong>${item.quantity} / мин. ${item.minQuantity}</strong></div>`);
        fillList('supplierPurchasesList', result.supplierPurchases, item => `
            <div class="analytics-list-item"><span>${item.name || '—'}</span><strong>${fmtMoney(item.totalAmount)} · ${item.purchasesCount} закуп.</strong></div>`);
        fillList('recentOrdersList', result.recentOrders, item => `
            <div class="analytics-list-item"><span>#${item.id} · ${item.customerName || 'Без клиента'}<div class="small text-muted">${item.saleDate}</div></span><strong>${fmtMoney(item.totalAmount)} / ${fmtMoney(item.profit)}</strong></div>`);
    }

    function fillList(id, items, renderer) {
        const container = el(id);
        if (!items || !items.length) {
            container.innerHTML = '<div class="text-muted small">Нет данных для отображения.</div>';
            return;
        }
        container.innerHTML = items.map(renderer).join('');
    }

    async function exportAnalytics() {
        if (!state.settings) return alert('Сначала подключи базу данных.');
        const response = await apiRequest('/Export/AnalyticsCsv', {
            settings: state.settings,
            inventoryTableName: currentTableName(),
            salesTableName: 'sales',
            saleItemsTableName: 'sale_items',
            purchasesTableName: 'purchases',
            purchaseItemsTableName: 'purchase_items',
            suppliersTableName: 'suppliers',
            categoriesTableName: 'categories'
        });
        if (!response.ok) {
            alert(await response.text());
            return;
        }
        const blob = await response.blob();
        downloadBlob(blob, 'analytics_export.csv');
    }
        function printAnalytics() {
        alert('Печать аналитики временно отключена.');
        }

       

    function downloadBlob(blob, fileName) {
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = fileName;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
    }

    el('btnFinanceConnect').addEventListener('click', connectAndLoadTables);
    el('refreshFinanceBtn').addEventListener('click', loadDashboard);
    el('financeTableComboBox').addEventListener('change', loadDashboard);
    el('financePeriod').addEventListener('change', loadDashboard);
    el('exportAnalyticsBtn').addEventListener('click', exportAnalytics);
    el('printAnalyticsBtn').addEventListener('click', printAnalytics);

    const saved = localStorage.getItem(localSettingsKey);
    if (saved) {
        try {
            const settings = JSON.parse(saved);
            fillSettingsForm(settings);
            state.settings = settings;
            connectAndLoadTables();
        } catch {}
    }
})();
</script>
}
