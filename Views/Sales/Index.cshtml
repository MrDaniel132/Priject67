@{
    ViewData["Title"] = "Продажа запчастей";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="main-container page-shell">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="fw-bold h3 mb-1">Оформление продажи</h1>
            <p class="text-muted mb-0">Создание заказа, данные клиента и подбор позиций со склада</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-dark" asp-controller="Parts" asp-action="Index"><i class="bi bi-arrow-left me-2"></i>К каталогу</a>
            <button type="button" class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#salesConnectModal"><i class="bi bi-database-add me-2"></i>Подключить БД</button>
        </div>
    </div>

    <ul class="nav nav-pills app-tabs mb-4">
        @if (User.IsInRole("Кассир") || User.IsInRole("Администратор") || User.IsInRole("Менеджер") || User.IsInRole("Кладовщик"))
        {
            @* каталог *@
            <li class="nav-item"><a class="nav-link active" asp-controller="Parts" asp-action="Index"><i class="bi bi-list-ul me-2"></i>Каталог товаров</a></li>
        }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кассир"))
        {
            @* продажи *@
            <li class="nav-item"><a class="nav-link" asp-controller="Sales" asp-action="Index"><i class="bi bi-bag-check me-2"></i>Продажи</a></li>
        }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кладовщик") || User.IsInRole("Менеджер"))
        {
            @* закупки *@
            <li class="nav-item"><a class="nav-link" asp-controller="Purchases" asp-action="Index"><i class="bi bi-truck me-2"></i>Закупки</a></li>
        }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кладовщик") || User.IsInRole("Менеджер"))
        {
            @* поставщики *@
            <li class="nav-item"><a class="nav-link" asp-controller="Suppliers" asp-action="Index"><i class="bi bi-truck-flatbed me-2"></i>Поставщики</a></li>
        }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кассир") || User.IsInRole("Менеджер"))
        {
            @* категории *@
            <li class="nav-item"><a class="nav-link" asp-controller="Categories" asp-action="Index"><i class="bi bi-tags me-2"></i>Категории</a></li>
        }
        @if (User.IsInRole("Администратор"))
        {
            @* журнал *@
            <li class="nav-item"><a class="nav-link" asp-controller="Audit" asp-action="Index"><i class="bi bi-journal-text me-2"></i>Журнал действий</a></li>
        }
        @if (User.IsInRole("Администратор") || User.IsInRole("Менеджер"))
        {
            @* аналитика *@
            <li class="nav-item"><a class="nav-link" asp-controller="Finance" asp-action="Index"><i class="bi bi-bar-chart me-2"></i>Аналитика</a></li>
        }
        @if (User.IsInRole("Администратор"))
        {
            @* сотрудники *@
            <li class="nav-item"><a class="nav-link" asp-controller="Employees" asp-action="Index"><i class="bi bi-person-circle"></i> Сотрудники</a></li>
        }
    </ul>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card app-card border-0 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                        <div>
                            <h5 class="mb-1">Товары для заказа</h5>
                            <div class="text-muted small">Выбери таблицу склада и добавь нужные позиции в заказ</div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <select id="salesTableComboBox" class="form-select app-select" style="min-width: 210px;">
                                <option value="">Таблица товаров</option>
                            </select>
                            <div class="input-group search-box" style="min-width: 280px;">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" id="salesSearchInput" class="form-control border-start-0" placeholder="Артикул, название, бренд...">
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Артикул</th>
                                    <th>Название</th>
                                    <th>Бренд</th>
                                    <th>Цена</th>
                                    <th>Остаток</th>
                                    <th class="text-end">Действие</th>
                                </tr>
                            </thead>
                            <tbody id="salesPartsTableBody">
                                <tr><td colspan="6" class="text-center text-muted py-4">Сначала подключи базу данных и выбери таблицу.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card app-card border-0 mb-4">
                <div class="card-body p-4">
                    <h5 class="mb-3">Данные клиента</h5>
                    <div class="mb-3">
                        <label class="form-label small text-muted fw-semibold">ФИО / название клиента</label>
                        <input type="text" id="customerName" class="form-control" placeholder="Например, Иванов И.И.">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted fw-semibold">Телефон</label>
                        <input type="text" id="customerPhone" class="form-control" placeholder="+375 (29) 123-45-67">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted fw-semibold">Email</label>
                        <input type="email" id="customerEmail" class="form-control" placeholder="client@mail.com">
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-sm-6">
                            <label class="form-label small text-muted fw-semibold">Оплата</label>
                            <select id="paymentMethod" class="form-select">
                                <option value="cash">Наличные</option>
                                <option value="card">Карта</option>
                                <option value="bank_transfer">Безналичный расчет</option>
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label small text-muted fw-semibold">Статус</label>
                            <select id="saleStatus" class="form-select">
                                <option value="completed">Завершен</option>
                                <option value="pending">В обработке</option>
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="form-label small text-muted fw-semibold">Комментарий</label>
                        <textarea id="saleNote" class="form-control" rows="3" placeholder="Комментарий к заказу, примечание для менеджера..."></textarea>
                    </div>
                </div>
            </div>

            <div class="card app-card border-0">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0">Состав заказа</h5>
                        <span class="badge rounded-pill text-bg-light" id="cartItemsCount">0 позиций</span>
                    </div>

                    <div id="salesCartEmpty" class="text-muted small py-3">Корзина пока пустая. Добавь товары из списка слева.</div>
                    <div class="table-responsive d-none" id="salesCartWrapper">
                        <table class="table align-middle mb-3">
                            <thead>
                                <tr>
                                    <th>Товар</th>
                                    <th>Кол-во</th>
                                    <th>Сумма</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="salesCartTableBody"></tbody>
                        </table>
                    </div>

                    <div class="order-summary-box">
                        <div class="d-flex justify-content-between mb-2"><span class="text-muted">Товаров</span><strong id="summaryQuantity">0 шт.</strong></div>
                        <div class="d-flex justify-content-between mb-2"><span class="text-muted">Позиций</span><strong id="summaryPositions">0</strong></div>
                        <div class="d-flex justify-content-between fs-5"><span class="fw-semibold">Итого</span><strong id="summaryTotal">0 BYN</strong></div>
                    </div>

                    <button id="submitSalesOrderBtn" class="btn btn-dark w-100 mt-3"><i class="bi bi-check2-circle me-2"></i>Оформить продажу</button>
                    <div id="salesResultMessage" class="small mt-3"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="card app-card border-0">
        <div class="card-body p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
                <div>
                    <h4 class="mb-1">История продаж</h4>
                    <div class="text-muted small">Список оформленных заказов и быстрый просмотр деталей по каждой продаже</div>
                </div>
                <div class="d-flex gap-2 flex-wrap align-items-center">
                    <div class="input-group search-box" style="min-width: 290px;">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" id="salesHistorySearchInput" class="form-control border-start-0" placeholder="Номер заказа, клиент, телефон...">
                    </div>
                    <button id="refreshSalesHistoryBtn" class="btn btn-outline-dark"><i class="bi bi-arrow-clockwise me-2"></i>Обновить</button>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="order-summary-box h-100">
                        <div class="text-muted small mb-1">Количество заказов</div>
                        <div class="fs-3 fw-bold" id="historyOrderCount">0</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="order-summary-box h-100">
                        <div class="text-muted small mb-1">Выручка по списку</div>
                        <div class="fs-3 fw-bold" id="historyRevenue">0 BYN</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="order-summary-box h-100">
                        <div class="text-muted small mb-1">Продано единиц</div>
                        <div class="fs-3 fw-bold" id="historyItems">0</div>
                    </div>
                </div>
            </div>

            <div id="salesHistoryMessage" class="small text-muted mb-3">Подключись к базе данных, чтобы загрузить историю заказов.</div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Заказ</th>
                            <th>Дата</th>
                            <th>Клиент</th>
                            <th>Статус</th>
                            <th>Состав</th>
                            <th>Сумма</th>
                            <th class="text-end">Действие</th>
                        </tr>
                    </thead>
                    <tbody id="salesHistoryTableBody">
                        <tr><td colspan="7" class="text-center text-muted py-4">История продаж пока не загружена.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="salesConnectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Настройки подключения</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label>Сервер</label>
                    <input type="text" id="salesDbServer" class="form-control" value="localhost">
                </div>
                <div class="mb-2">
                    <label>Порт</label>
                    <input type="text" id="salesDbPort" class="form-control" value="3306">
                </div>
                <div class="mb-2">
                    <label>База данных</label>
                    <input type="text" id="salesDbName" class="form-control" value="auto_parts_store">
                </div>
                <div class="row">
                    <div class="col"><label>Логин</label><input type="text" id="salesDbUser" class="form-control" value="root"></div>
                    <div class="col"><label>Пароль</label><input type="password" id="salesDbPass" class="form-control" value="root"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" id="btnSalesConnect" class="btn btn-dark w-100">Подключиться и загрузить таблицы</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="saleDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title mb-1">Детали заказа <span id="saleDetailsTitleId"></span></h5>
                    <div class="small text-muted" id="saleDetailsSubTitle">Информация о клиенте и составе продажи</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="order-summary-box h-100">
                            <div class="small text-muted mb-2">Клиент</div>
                            <div class="fw-semibold" id="detailCustomerName">—</div>
                            <div class="small text-muted mt-2" id="detailCustomerContacts">—</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="order-summary-box h-100">
                            <div class="small text-muted mb-2">Параметры продажи</div>
                            <div class="d-flex justify-content-between mb-2"><span class="text-muted">Дата</span><strong id="detailSaleDate">—</strong></div>
                            <div class="d-flex justify-content-between mb-2"><span class="text-muted">Оплата</span><strong id="detailPaymentMethod">—</strong></div>
                            <div class="d-flex justify-content-between"><span class="text-muted">Статус</span><strong id="detailStatus">—</strong></div>
                        </div>
                    </div>
                </div>

                <div class="order-summary-box mb-4">
                    <div class="small text-muted mb-2">Комментарий</div>
                    <div id="detailNote">—</div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Артикул</th>
                                <th>Товар</th>
                                <th>Кол-во</th>
                                <th>Цена</th>
                                <th>Сумма</th>
                                <th>Возвращено</th>
                                <th>Возврат</th>
                            </tr>
                        </thead>
                        <tbody id="saleDetailsItemsBody">
                            <tr><td colspan="7" class="text-center text-muted py-4">Нет данных по составу заказа.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div id="detailReturnMessage" class="small text-muted px-3 pb-1"></div>
            <div class="modal-footer justify-content-between">
                <div class="d-flex gap-3 flex-wrap small">
                    <span class="text-muted">Продано единиц: <strong class="text-dark" id="detailTotalQuantity">0</strong></span>
                    <span class="text-muted">Оценочная прибыль: <strong class="text-dark" id="detailEstimatedProfit">0 BYN</strong></span>
                </div>
                <div class="fw-semibold">Итого: <span id="detailTotalAmount">0 BYN</span></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const state = { settings: null, allRows: [], cart: [], history: [], currentOrderDetails: null };
            const localSettingsKey = 'autoPartsDbSettings';
            const el = (id) => document.getElementById(id);

            function parseNumber(value) {
                if (value === null || value === undefined) return 0;
                if (typeof value === 'number') return Number.isFinite(value) ? value : 0;

                const normalized = String(value)
                    .trim()
                    .replace(/\s+/g, '')
                    .replace(/,/g, '.');

                const parsed = Number(normalized);
                return Number.isFinite(parsed) ? parsed : 0;
            }

            function getPriceValue(row) {
                const directPrice = getField(row, '__resolvedPrice', 'sale_price', 'retail_price', 'selling_price', 'unit_price', 'price');
                if (directPrice !== '') return parseNumber(directPrice);

                const purchaseLikeNames = ['purchase_price', 'cost_price', 'buy_price', 'incoming_price', 'wholesale_price'];
                const keys = Object.keys(row);

                const matchedKey = keys.find(key => {
                    const normalized = key.toLowerCase();
                    if (purchaseLikeNames.includes(normalized)) return false;
                    return normalized.includes('price')
                        || normalized.includes('цена')
                        || normalized.includes('стоимость')
                        || normalized.includes('sum');
                });

                return matchedKey ? parseNumber(row[matchedKey]) : 0;
            }

            function getPurchasePriceValue(row) {
                const purchasePrice = getField(row, 'purchase_price', 'cost_price', 'buy_price', 'incoming_price', 'wholesale_price', '__resolvedPrice');
                if (purchasePrice !== '') return parseNumber(purchasePrice);
                return getPriceValue(row);
            }

            const formatMoney = (value) => `${parseNumber(value).toLocaleString('ru-RU', { minimumFractionDigits: 0, maximumFractionDigits: 2 })} BYN`;
            const mapPaymentMethod = (value) => ({ cash: 'Наличные', card: 'Карта', bank_transfer: 'Безналичный расчет' }[value] || value || '—');
            const mapStatus = (value) => ({ completed: 'Завершен', pending: 'В обработке' }[value] || value || '—');

            function statusBadge(value) {
                const isCompleted = String(value).toLowerCase() === 'completed';
                return `<span class="badge rounded-pill ${isCompleted ? 'text-bg-success-subtle text-success-emphasis' : 'text-bg-warning-subtle text-warning-emphasis'}">${mapStatus(value)}</span>`;
            }

            function getSettingsFromForm() {
                return {
                    server: el('salesDbServer').value,
                    port: el('salesDbPort').value,
                    database: el('salesDbName').value,
                    username: el('salesDbUser').value,
                    password: el('salesDbPass').value
                };
            }

            function fillSettingsForm(settings) {
                if (!settings) return;
                el('salesDbServer').value = settings.server || 'localhost';
                el('salesDbPort').value = settings.port || '3306';
                el('salesDbName').value = settings.database || 'auto_parts_store';
                el('salesDbUser').value = settings.username || 'root';
                el('salesDbPass').value = settings.password || 'root';
            }

            async function apiRequest(url, data) {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                return await response.json();
            }

            function getField(row, ...names) {
                for (const name of names) {
                    const key = Object.keys(row).find(k => k.toLowerCase() === name.toLowerCase());
                    if (key) return row[key];
                }
                return '';
            }

            function currentTableName() {
                return el('salesTableComboBox').value;
            }

            function renderParts(rows) {
                const tbody = el('salesPartsTableBody');
                if (!rows.length) {
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">По выбранным условиям ничего не найдено.</td></tr>';
                    return;
                }

                tbody.innerHTML = rows.map(row => {
                    const id = getField(row, 'id');
                    const partNumber = getField(row, '__resolvedPartNumber', 'part_number', 'SKU');
                    const partName = getField(row, '__resolvedPartName', 'part_name', 'name');
                    const brand = getField(row, '__resolvedBrand', 'brand', 'manufacturer');
                    const price = getPriceValue(row);
                    const quantity = parseNumber(getField(row, '__resolvedQuantity', 'quantity', 'stock'));
                    const disabled = quantity <= 0 ? 'disabled' : '';

                    return `
                        <tr>
                            <td class="fw-semibold">${partNumber || '—'}</td>
                            <td>${partName || '—'}</td>
                            <td>${brand || '—'}</td>
                            <td>${formatMoney(price)}</td>
                            <td>${quantity} шт.</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-dark" ${disabled} data-action="add" data-id="${id || ''}" data-number="${partNumber || ''}">
                                    <i class="bi bi-plus-lg me-1"></i>Добавить
                                </button>
                            </td>
                        </tr>`;
                }).join('');
            }

            function filterAndRenderParts() {
                const query = el('salesSearchInput').value.trim().toLowerCase();
                const rows = state.allRows.filter(row => {
                    const quantity = parseNumber(getField(row, '__resolvedQuantity', 'quantity', 'stock'));
                    if (quantity <= 0) return false;
                    if (!query) return true;
                    return Object.values(row).some(v => String(v).toLowerCase().includes(query));
                });
                renderParts(rows);
            }

            function getCartTotals() {
                return {
                    totalQuantity: state.cart.reduce((sum, item) => sum + item.quantity, 0),
                    totalAmount: state.cart.reduce((sum, item) => sum + (item.quantity * item.salePrice), 0),
                    positions: state.cart.length
                };
            }

            function renderCart() {
                const empty = el('salesCartEmpty');
                const wrapper = el('salesCartWrapper');
                const tbody = el('salesCartTableBody');
                const totals = getCartTotals();

                el('cartItemsCount').innerText = `${totals.positions} позиций`;
                el('summaryQuantity').innerText = `${totals.totalQuantity} шт.`;
                el('summaryPositions').innerText = totals.positions;
                el('summaryTotal').innerText = formatMoney(totals.totalAmount);

                if (!state.cart.length) {
                    empty.classList.remove('d-none');
                    wrapper.classList.add('d-none');
                    tbody.innerHTML = '';
                    return;
                }

                empty.classList.add('d-none');
                wrapper.classList.remove('d-none');
                tbody.innerHTML = state.cart.map((item, index) => `
                    <tr>
                        <td><div class="fw-semibold">${item.partName}</div><div class="text-muted small">${item.partNumber || 'Без артикула'}</div></td>
                        <td style="width: 120px;"><input type="number" class="form-control form-control-sm" min="1" max="${item.maxQuantity}" value="${item.quantity}" data-action="qty" data-index="${index}"></td>
                        <td>${formatMoney(item.quantity * item.salePrice)}</td>
                        <td class="text-end"><button class="btn btn-sm btn-link text-danger p-0" data-action="remove" data-index="${index}"><i class="bi bi-x-lg"></i></button></td>
                    </tr>`).join('');
            }

            function renderHistory(orders, summary) {
                const tbody = el('salesHistoryTableBody');
                el('historyOrderCount').innerText = summary?.count ?? 0;
                el('historyRevenue').innerText = formatMoney(summary?.totalRevenue ?? 0);
                el('historyItems').innerText = summary?.totalItems ?? 0;

                if (!orders?.length) {
                    tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4">Продаж пока нет. Оформи первый заказ, и он появится здесь.</td></tr>';
                    return;
                }

                tbody.innerHTML = orders.map(order => `
                    <tr>
                        <td class="fw-semibold">#${order.id}</td>
                        <td>${order.saleDate}</td>
                        <td>
                            <div class="fw-semibold">${order.customerName || '—'}</div>
                            <div class="small text-muted">${order.customerPhone || order.customerEmail || 'Без контактов'}</div>
                        </td>
                        <td>${statusBadge(order.status)}</td>
                        <td>${order.positions} поз. / ${order.totalQuantity} шт.</td>
                        <td class="fw-semibold">${formatMoney(order.totalAmount)}</td>
                        <td class="text-end"><button class="btn btn-sm btn-outline-dark" data-action="details" data-sale-id="${order.id}"><i class="bi bi-eye me-1"></i>Открыть</button></td>
                    </tr>`).join('');
            }

            function fillOrderDetails(data) {
                const order = data.order;
                const items = data.items || [];
                el('saleDetailsTitleId').innerText = `#${order.id}`;
                el('saleDetailsSubTitle').innerText = `${order.saleDate} · ${mapStatus(order.status)}`;
                el('detailCustomerName').innerText = order.customerName || '—';
                el('detailCustomerContacts').innerText = [order.customerPhone, order.customerEmail].filter(Boolean).join(' · ') || 'Контакты не указаны';
                el('detailSaleDate').innerText = order.saleDate || '—';
                el('detailPaymentMethod').innerText = mapPaymentMethod(order.paymentMethod);
                el('detailStatus').innerText = mapStatus(order.status);
                el('detailNote').innerText = order.note || 'Комментарий не указан';
                el('detailTotalQuantity').innerText = data.summary?.totalQuantity ?? 0;
                el('detailEstimatedProfit').innerText = formatMoney(data.summary?.estimatedProfit ?? 0);
                el('detailTotalAmount').innerText = formatMoney(order.totalAmount || 0);

                const tbody = el('saleDetailsItemsBody');
                if (!items.length) {
                    tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4">Нет данных по составу заказа.</td></tr>';
                    state.currentOrderDetails = data;
                    return;
                }

                tbody.innerHTML = items.map(item => `
                    <tr>
                        <td>${item.partNumber || '—'}</td>
                        <td>${item.partName || '—'}</td>
                        <td>${item.quantity}</td>
                        <td>${formatMoney(item.salePrice)}</td>
                        <td class="fw-semibold">${formatMoney(item.lineTotal)}</td>
                        <td>${item.returnedQuantity || 0} шт.</td>
                        <td>
                            ${item.availableReturnQuantity > 0 ? `
                            <div class="input-group input-group-sm">
                                <input type="number" class="form-control" min="1" max="${item.availableReturnQuantity}" value="1" data-return-input="${item.id}">
                                <button class="btn btn-outline-danger" data-action="return-item" data-sale-item-id="${item.id}">Возврат</button>
                            </div>
                            <div class="small text-muted mt-1">Доступно: ${item.availableReturnQuantity} шт.</div>` : '<span class="text-muted small">Возврат оформлен</span>'}
                        </td>
                    </tr>`).join('');
                state.currentOrderDetails = data;
            }

            function addToCart(row, identifier) {
                const partNumber = getField(row, '__resolvedPartNumber', 'part_number', 'SKU');
                const partName = getField(row, '__resolvedPartName', 'part_name', 'name');
                const salePrice = getPriceValue(row);
                const maxQuantity = parseNumber(getField(row, '__resolvedQuantity', 'quantity', 'stock'));
                const purchasePrice = getPurchasePriceValue(row);
                const existing = state.cart.find(item => item.key === identifier);

                if (existing) {
                    if (existing.quantity < existing.maxQuantity) existing.quantity += 1;
                } else {
                    state.cart.push({ key: identifier, partId: getField(row, 'id') || null, partNumber, partName, salePrice, purchasePrice, quantity: 1, maxQuantity });
                }
                renderCart();
            }

            async function loadTableData() {
                const tableName = currentTableName();
                if (!tableName || !state.settings) return;
                const result = await apiRequest(`/Database/GetTableData?tableName=${encodeURIComponent(tableName)}`, state.settings);
                if (!result.success) {
                    el('salesPartsTableBody').innerHTML = `<tr><td colspan="6" class="text-center text-danger py-4">${result.message}</td></tr>`;
                    return;
                }
                state.allRows = result.rows;
                filterAndRenderParts();
            }

            async function loadSalesHistory() {
                if (!state.settings) return;

                const message = el('salesHistoryMessage');
                message.className = 'small text-muted mb-3';
                message.innerText = 'Загрузка истории продаж...';

                const result = await apiRequest('/Sales/GetOrders', {
                    settings: state.settings,
                    search: el('salesHistorySearchInput').value.trim(),
                    salesTableName: 'sales',
                    saleItemsTableName: 'sale_items',
                    limit: 50
                });

                if (!result.success) {
                    message.className = 'small text-danger mb-3';
                    message.innerText = result.message || 'Не удалось загрузить историю продаж.';
                    renderHistory([], { count: 0, totalRevenue: 0, totalItems: 0 });
                    return;
                }

                state.history = result.orders || [];
                message.className = 'small text-muted mb-3';
                message.innerText = state.history.length
                    ? 'Выбери заказ в таблице ниже, чтобы посмотреть его состав и данные клиента.'
                    : 'Продаж пока нет. Оформи первый заказ, и он появится здесь.';
                renderHistory(state.history, result.summary);
            }

            async function submitReturnItem(saleItemId) {
                if (!state.settings || !state.currentOrderDetails?.order) return;

                const input = document.querySelector(`[data-return-input="${saleItemId}"]`);
                const quantity = Math.max(1, parseNumber(input?.value || 1));
                const msg = el('detailReturnMessage');

                const result = await apiRequest('/Inventory/CreateReturn', {
                    settings: state.settings,
                    inventoryTableName: currentTableName(),
                    saleId: state.currentOrderDetails.order.id,
                    customerName: state.currentOrderDetails.order.customerName,
                    note: `Возврат по заказу #${state.currentOrderDetails.order.id}`,
                    items: [{ saleItemId: Number(saleItemId), quantity }]
                });

                if (!result.success) {
                    msg.className = 'small text-danger px-3 pb-1';
                    msg.innerText = result.message || 'Не удалось оформить возврат.';
                    return;
                }

                msg.className = 'small text-success px-3 pb-1';
                msg.innerText = `Возврат №${result.returnId} успешно оформлен.`;
                await openOrderDetails(state.currentOrderDetails.order.id);
                await loadSalesHistory();
                await loadTableData();
            }

            async function openOrderDetails(saleId) {
                if (!state.settings || !saleId) return;

                const result = await apiRequest('/Sales/GetOrderDetails', {
                    settings: state.settings,
                    salesTableName: 'sales',
                    saleItemsTableName: 'sale_items',
                    saleId: Number(saleId)
                });

                if (!result.success) {
                    alert(result.message || 'Не удалось загрузить детали заказа.');
                    return;
                }

                el('detailReturnMessage').className = 'small text-muted px-3 pb-1';
                el('detailReturnMessage').innerText = '';
                fillOrderDetails(result);
                bootstrap.Modal.getOrCreateInstance(el('saleDetailsModal')).show();
            }

            async function connectAndLoadTables() {
                const settings = getSettingsFromForm();
                const result = await apiRequest('/Database/GetTables', settings);
                if (!result.success) {
                    alert('Ошибка: ' + result.message);
                    return;
                }
                state.settings = settings;
                localStorage.setItem(localSettingsKey, JSON.stringify(settings));
                const combo = el('salesTableComboBox');
                combo.innerHTML = '<option value="">Таблица товаров</option>';
                result.tables.forEach(name => combo.insertAdjacentHTML('beforeend', `<option value="${name}">${name}</option>`));
                const preferred = result.tables.includes('parts') ? 'parts' : result.tables[0];
                combo.value = preferred;
                bootstrap.Modal.getInstance(el('salesConnectModal'))?.hide();
                await loadTableData();
                await loadSalesHistory();
            }

            async function submitOrder() {
                const tableName = currentTableName();
                if (!state.settings) return alert('Сначала подключи базу данных.');
                if (!tableName) return alert('Выбери таблицу товаров.');
                if (!state.cart.length) return alert('Добавь в заказ хотя бы один товар.');
                if (!el('customerName').value.trim()) return alert('Укажи имя клиента.');

                const payload = {
                    settings: state.settings,
                    inventoryTableName: tableName,
                    customerName: el('customerName').value.trim(),
                    customerPhone: el('customerPhone').value.trim(),
                    customerEmail: el('customerEmail').value.trim(),
                    note: el('saleNote').value.trim(),
                    paymentMethod: el('paymentMethod').value,
                    status: el('saleStatus').value,
                    items: state.cart.map(item => ({ partId: item.partId, partNumber: item.partNumber, partName: item.partName, salePrice: item.salePrice, purchasePrice: item.purchasePrice, quantity: item.quantity }))
                };

                const result = await apiRequest('/Sales/CreateOrder', payload);
                const msg = el('salesResultMessage');
                if (result.success) {
                    msg.className = 'small mt-3 text-success';
                    msg.innerText = `Заказ №${result.saleId} успешно оформлен.`;
                    state.cart = [];
                    renderCart();
                    el('customerName').value = '';
                    el('customerPhone').value = '';
                    el('customerEmail').value = '';
                    el('saleNote').value = '';
                    await loadTableData();
                    await loadSalesHistory();
                } else {
                    msg.className = 'small mt-3 text-danger';
                    msg.innerText = result.message || 'Не удалось оформить заказ.';
                }
            }

            el('btnSalesConnect').addEventListener('click', connectAndLoadTables);
            el('salesTableComboBox').addEventListener('change', loadTableData);
            el('salesSearchInput').addEventListener('input', filterAndRenderParts);
            el('submitSalesOrderBtn').addEventListener('click', submitOrder);
            el('refreshSalesHistoryBtn').addEventListener('click', loadSalesHistory);
            el('salesHistorySearchInput').addEventListener('input', () => {
                clearTimeout(window.salesHistoryTimer);
                window.salesHistoryTimer = setTimeout(loadSalesHistory, 250);
            });

            el('salesPartsTableBody').addEventListener('click', (event) => {
                const button = event.target.closest('[data-action="add"]');
                if (!button) return;
                const identifier = button.dataset.id || button.dataset.number;
                const row = state.allRows.find(r => String(getField(r, 'id') || '') === button.dataset.id || String(getField(r, '__resolvedPartNumber', 'part_number', 'SKU') || '') === button.dataset.number);
                if (row) addToCart(row, identifier);
            });

            el('salesCartTableBody').addEventListener('input', (event) => {
                const input = event.target.closest('[data-action="qty"]');
                if (!input) return;
                const index = Number(input.dataset.index);
                const item = state.cart[index];
                if (!item) return;
                let value = Number(input.value) || 1;
                value = Math.max(1, Math.min(value, item.maxQuantity));
                item.quantity = value;
                input.value = value;
                renderCart();
            });

            el('salesCartTableBody').addEventListener('click', (event) => {
                const button = event.target.closest('[data-action="remove"]');
                if (!button) return;
                state.cart.splice(Number(button.dataset.index), 1);
                renderCart();
            });

            el('salesHistoryTableBody').addEventListener('click', (event) => {
                const button = event.target.closest('[data-action="details"]');
                if (!button) return;
                openOrderDetails(button.dataset.saleId);
            });

            el('saleDetailsItemsBody').addEventListener('click', (event) => {
                const button = event.target.closest('[data-action="return-item"]');
                if (!button) return;
                submitReturnItem(button.dataset.saleItemId);
            });

            const saved = localStorage.getItem(localSettingsKey);
            if (saved) {
                try {
                    const settings = JSON.parse(saved);
                    fillSettingsForm(settings);
                    state.settings = settings;
                    connectAndLoadTables();
                } catch {}
            }

            renderCart();
        })();
    </script>
}
