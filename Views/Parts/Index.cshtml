@model IEnumerable<MyWebApp.Models.PartViewModel>

@{
    ViewData["Title"] = "База запчастей";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="main-container page-shell">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="fw-bold h3 mb-1">База данных автозапчастей</h1>
            <p class="text-muted mb-0">Управление складом, фильтрация, поставщики, категории и подготовка продаж</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-dark" asp-controller="Sales" asp-action="Index"><i class="bi bi-bag-check me-2"></i>Продажи</a>
            <a class="btn btn-outline-dark" asp-controller="Purchases" asp-action="Index"><i class="bi bi-truck me-2"></i>Закупки</a>
            <button class="btn btn-outline-dark" id="exportPartsBtn"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Экспорт CSV</button>
            @if (User.IsInRole("Администратор"))
            {
                <a class="btn btn-dark" asp-controller="Audit" asp-action="Index"><i class="bi bi-journal-text me-2"></i>Журнал действий</a>
            }
            <div class="theme-toggle" id="themeSwitcher" title="Переключить тему">
                <i class="bi bi-moon-stars-fill"></i>
            </div>
        </div>
    </div>

    <ul class="nav nav-pills app-tabs mb-4 flex-wrap gap-2">
       
        
        @if (User.IsInRole("Кассир") || User.IsInRole("Администратор") || User.IsInRole("Менеджер") || User.IsInRole("Кладовщик"))
            {
               @* каталог *@ <li class="nav-item"><a class="nav-link active" asp-controller="Parts" asp-action="Index"><i class="bi bi-list-ul me-2"></i>Каталог товаров</a></li>
            }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кассир"))
            {
               @* продажи *@<li class="nav-item"><a class="nav-link" asp-controller="Sales" asp-action="Index"><i class="bi bi-bag-check me-2"></i>Продажи</a></li>
            }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кладовщик") || User.IsInRole("Менеджер"))
            {
                @* закупки *@<li class="nav-item"><a class="nav-link" asp-controller="Purchases" asp-action="Index"><i class="bi bi-truck me-2"></i>Закупки</a></li>
            }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кладовщик") || User.IsInRole("Менеджер"))
            {
                @* поставщики *@<li class="nav-item"><a class="nav-link" asp-controller="Suppliers" asp-action="Index"><i class="bi bi-truck-flatbed me-2"></i>Поставщики</a></li>
            }
        @if (User.IsInRole("Администратор") || User.IsInRole("Кассир") || User.IsInRole("Менеджер"))
            {
                @* категории *@<li class="nav-item"><a class="nav-link" asp-controller="Categories" asp-action="Index"><i class="bi bi-tags me-2"></i>Категории</a></li>
            }
        @if (User.IsInRole("Администратор"))
            {
                @* журнал *@<li class="nav-item"><a class="nav-link" asp-controller="Audit" asp-action="Index"><i class="bi bi-journal-text me-2"></i>Журнал действий</a></li>
            }
        @if (User.IsInRole("Администратор") || User.IsInRole("Менеджер"))
            {
                @* аналитика *@<li class="nav-item"><a class="nav-link" asp-controller="Finance" asp-action="Index"><i class="bi bi-bar-chart me-2"></i>Аналитика</a></li>
            }
        @if (User.IsInRole("Администратор"))
            {
            @* сотрудники *@
            <li class="nav-item"><a class="nav-link" asp-controller="Employees" asp-action="Index"><i class="bi bi-person-circle"></i> Сотрудники</a></li>
            }
    </ul>

    <div class="row g-3 mb-4">
        <div class="col"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Всего позиций</span><i class="bi bi-box"></i></div><div id="totalPositionsCount" class="stat-value">0</div><div class="stat-sub">В каталоге склада</div></div></div>
        <div class="col"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">В наличии</span><i class="bi bi-check2-circle"></i></div><div id="inStockCount" class="stat-value">0</div><div class="stat-sub">Доступно к продаже</div></div></div>
        <div class="col"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Нет на складе</span><i class="bi bi-exclamation-triangle"></i></div><div id="outOfStockCount" class="stat-value">0</div><div class="stat-sub">Нужно пополнить</div></div></div>
        <div class="col"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Общая стоимость</span><i class="bi bi-currency-dollar"></i></div><div id="totalInventoryValue" class="stat-value">0 BYN</div><div class="stat-sub">Складской запас</div></div></div>
        <div class="col"><div class="stat-card"><div class="d-flex justify-content-between text-muted"><span class="stat-label">Низкий остаток</span><i class="bi bi-bell"></i></div><div id="lowStockCount" class="stat-value">0</div><div class="stat-sub">Требуют пополнения</div></div></div>
    </div>

    

    <p class="text-muted small mb-2">Найдено запчастей: <strong id="partsCountText">0</strong></p>

    <div class="table-container mb-4">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2"><div><h5 class="mb-1">Уведомления по остаткам</h5><div class="small text-muted">Список товаров, которые нужно срочно пополнить</div></div><span id="lowStockBadge" class="badge text-bg-light">0 уведомлений</span></div>
        <div class="table-responsive"><table class="table align-middle mb-0"><thead><tr><th>Артикул</th><th>Название</th><th>Остаток</th><th>Минимум</th><th>Статус</th></tr></thead><tbody id="lowStockTableBody"><tr><td colspan="5" class="text-center text-muted py-4">Подключи базу данных, чтобы увидеть проблемные остатки.</td></tr></tbody></table></div>
    </div>


    <div class="card app-card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <div class="d-flex flex-wrap align-items-end gap-3">
                <div class="flex-grow-1" style="min-width: 250px;">
                    <label class="form-label text-muted small fw-bold mb-1">Поиск</label>
                    <div class="input-group search-box"><span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span><input type="text" id="tableSearchInput" class="form-control border-start-0" placeholder="Артикул, название, марка..."></div>
                </div>
                <div style="min-width: 220px;"><label class="form-label text-muted small fw-bold mb-1">Таблица</label><select id="tableComboBox" class="form-select app-select"><option value="">Выберите таблицу</option></select></div>
                <div class="d-flex gap-2 ms-auto flex-wrap">
                    <button type="button" class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#connectModal"><i class="bi bi-database-add me-2"></i>Подключить БД</button>
                    <div class="dropdown">
                        <button class="btn btn-dark dropdown-toggle d-flex align-items-center" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i>
                            <span class="ms-2 d-none d-lg-inline">@User.Identity?.Name (@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                            <li><h6 class="dropdown-header text-uppercase small text-muted">Управление</h6></li>
                            @* <li><a class="dropdown-item" asp-controller="Sales" asp-action="Index">Продажи</a></li> *@
                            @if (User.IsInRole("Администратор"))
                            {
                                @* <li><a class="dropdown-item" asp-controller="Suppliers" asp-action="Index">Поставщики</a></li>
                                <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index">Категории</a></li> *@
                                <li><a class="dropdown-item" asp-controller="Audit" asp-action="Index">Журнал действий</a></li>
                            }
                            @if (User.IsInRole("Администратор") || User.IsInRole("Менеджер"))
                            {
                                @* <li><a class="dropdown-item" asp-controller="Finance" asp-action="Index">Аналитика</a></li> *@
                            }
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">Выйти</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="row g-3 mt-2">
                <div class="col-md-2"><label class="form-label text-muted small fw-bold mb-1">Бренд</label><select id="brandFilter" class="form-select"><option value="">Все</option></select></div>
                <div class="col-md-2"><label class="form-label text-muted small fw-bold mb-1">Модель авто</label><select id="modelFilter" class="form-select"><option value="">Все</option></select></div>
                <div class="col-md-2"><label class="form-label text-muted small fw-bold mb-1">Категория</label><select id="categoryFilter" class="form-select"><option value="">Все</option></select></div>
                <div class="col-md-2"><label class="form-label text-muted small fw-bold mb-1">Поставщик</label><select id="supplierFilter" class="form-select"><option value="">Все</option></select></div>
                <div class="col-md-2"><label class="form-label text-muted small fw-bold mb-1">Наличие</label><select id="stockFilter" class="form-select"><option value="">Все</option><option value="instock">В наличии</option><option value="low">Низкий остаток</option><option value="out">Нет на складе</option></select></div>
                <div class="col-md-2"><label class="form-label text-muted small fw-bold mb-1">Сортировка</label><select id="sortFilter" class="form-select"><option value="name_asc">Название ↑</option><option value="name_desc">Название ↓</option><option value="price_asc">Цена ↑</option><option value="price_desc">Цена ↓</option><option value="quantity_desc">Остаток ↓</option><option value="quantity_asc">Остаток ↑</option></select></div>
                <div class="col-md-2"><label class="form-label text-muted small fw-bold mb-1">Цена от</label><input id="minPriceFilter" type="number" step="0.01" min="0" class="form-control" placeholder="0"></div>
                <div class="col-md-2"><label class="form-label text-muted small fw-bold mb-1">Цена до</label><input id="maxPriceFilter" type="number" step="0.01" min="0" class="form-control" placeholder="∞"></div>
                <div class="col-md-2 d-flex align-items-end"><button id="resetFiltersBtn" class="btn btn-outline-secondary w-100">Сбросить фильтры</button></div>
            </div>
        </div>
    </div>

    <div class="table-container">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Артикул</th>
                        <th>Название</th>
                        <th>Марка авто</th>
                        <th>Модель авто</th>
                        <th>Бренд</th>
                        <th>Категория</th>
                        <th>Поставщик</th>
                        <th>Цена</th>
                        <th>Остаток</th>
                        <th>Статус</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody id="partsTableBody"><tr><td colspan="11" class="text-center text-muted py-4">Подключи базу данных и выбери таблицу для загрузки запчастей.</td></tr></tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="connectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Настройки подключения</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-2"><label>Сервер</label><input type="text" id="dbServer" class="form-control" value="localhost"></div><div class="mb-2"><label>Порт</label><input type="text" id="dbPort" class="form-control" value="3306"></div><div class="mb-2"><label>База данных</label><input type="text" id="dbName" class="form-control" value="myfinanceapp_db"></div><div class="row"><div class="col"><label>Логин</label><input type="text" id="dbUser" class="form-control" value="root"></div><div class="col"><label>Пароль</label><input type="password" id="dbPass" class="form-control" value="root"></div></div></div><div class="modal-footer"><button type="button" id="btnDoConnect" class="btn btn-dark w-100">Подключиться и загрузить таблицы</button></div></div></div>
</div>

<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg"><div class="modal-content"><div class="modal-header"><h5 class="modal-title">Редактирование записи</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><form id="editForm"><div class="row g-3" id="dynamicFormFields"></div></form></div><div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отмена</button><button type="button" id="saveEditBtn" class="btn btn-dark" onclick="saveChanges()">Сохранить</button></div></div></div>
</div>

<div class="modal fade" id="productCardModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content"><div class="modal-header"><div><h5 class="modal-title mb-1">Карточка товара <span id="productCardTitle"></span></h5><div class="small text-muted" id="productCardSubtitle">Подробности о позиции, остатках и движении</div></div><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="row g-3 mb-4"><div class="col-md-3"><div class="order-summary-box h-100"><div class="small text-muted mb-1">Остаток</div><div class="fs-3 fw-bold" id="cardQuantity">0 шт.</div><div class="small text-muted">Текущее наличие</div></div></div><div class="col-md-3"><div class="order-summary-box h-100"><div class="small text-muted mb-1">Минимум</div><div class="fs-3 fw-bold" id="cardMinQuantity">0 шт.</div><div class="small text-muted">Порог пополнения</div></div></div><div class="col-md-3"><div class="order-summary-box h-100"><div class="small text-muted mb-1">Цена продажи</div><div class="fs-3 fw-bold" id="cardSalePrice">0 BYN</div><div class="small text-muted">Текущая цена</div></div></div><div class="col-md-3"><div class="order-summary-box h-100"><div class="small text-muted mb-1">Статус</div><div class="fs-4 fw-bold" id="cardLowStockStatus">В норме</div><div class="small text-muted" id="cardStockValue">Стоимость остатка 0 BYN</div></div></div></div><div class="row g-4"><div class="col-lg-5"><div class="table-container h-100"><h5 class="mb-3">Основные данные</h5><div class="row g-3" id="productCardFields"></div></div></div><div class="col-lg-7"><div class="table-container mb-4"><h5 class="mb-3">Сводка по товару</h5><div class="row g-3"><div class="col-md-6"><div class="order-summary-box"><div class="small text-muted mb-1">Продано всего</div><div class="fs-4 fw-bold" id="cardSoldUnits">0 шт.</div><div class="small text-muted" id="cardSoldAmount">0 BYN</div></div></div><div class="col-md-6"><div class="order-summary-box"><div class="small text-muted mb-1">Закуплено всего</div><div class="fs-4 fw-bold" id="cardPurchasedUnits">0 шт.</div><div class="small text-muted" id="cardPurchasedAmount">0 BYN</div></div></div></div></div><div class="table-container"><div class="d-flex justify-content-between align-items-center mb-3"><h5 class="mb-0">История движения</h5><span class="small text-muted">Последние операции по товару</span></div><div class="table-responsive"><table class="table align-middle mb-0"><thead><tr><th>Дата</th><th>Тип</th><th>Изменение</th><th>Цена</th><th>Комментарий</th></tr></thead><tbody id="productMovementsBody"><tr><td colspan="5" class="text-center text-muted py-4">Нет данных по движению товара.</td></tr></tbody></table></div></div></div></div></div></div></div>
</div>
