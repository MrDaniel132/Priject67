@model MyFinanceApp.Models.LoginViewModel

@{
    Layout = null; // Отключаем общий Layout, чтобы страница была чистой
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Вход в систему</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
        }

        .login-card {
            background: white;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            width: 100%;
            max-width: 400px;
        }

        .btn-dark {
            background-color: #000;
            border: none;
            border-radius: 8px;
            padding: 12px;
            font-weight: 500;
        }

        .form-control {
            border-radius: 8px;
            padding: 12px;
            border: 1px solid #dee2e6;
        }

            .form-control:focus {
                border-color: #000;
                box-shadow: none;
            }

        .logo-icon {
            font-size: 2.5rem;
            color: #000;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

    <div class="login-card text-center">
        <div class="logo-icon">
            <i class="bi bi-shield-lock"></i>
        </div>
        <h3 class="fw-bold mb-1">Складской учет</h3>
        <p class="text-muted mb-4">Введите данные для входа</p>

        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3 text-start">
                <label class="form-label small fw-bold text-muted">Логин</label>
                <input asp-for="Username" class="form-control" placeholder="admin" required maxlength="50" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="mb-4 text-start">
                <label class="form-label small fw-bold text-muted">Пароль</label>
                <input asp-for="Password" class="form-control" placeholder="•••••" required maxlength="100" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-dark w-100 mb-3">Войти в систему</button>

            <p class="text-muted small">Забыли пароль? Обратитесь к админу.</p>

        
        </form>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>